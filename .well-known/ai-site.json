{
  "schema_version": "1.0",
  "name": "Decent Apartments",
  "description": "Apartment-finding resource with practical renter articles about listings, tours, costs, lease basics, red flags, and rental tradeoffs",
  "version": "1.0",
  "url": "https://decent.apartments",
  "content_types": [
    "renter_articles",
    "apartment_search_guides",
    "checklists",
    "how-to",
    "housing_resources"
  ],
  "topics": [
    "apartment_search",
    "rental_applications",
    "lease_basics",
    "security_deposits",
    "renter_budgeting",
    "apartment_tours",
    "rental_red_flags",
    "property_management",
    "move_in_preparation",
    "neighborhood_fit"
  ],
  "article_stages": [
    "getting_started",
    "active_search",
    "deep_dive"
  ],
  "resources": {
    "articles": {
      "url": "/api/guides.json",
      "description": "Complete list of renter articles with metadata",
      "format": "json",
      "updated": "realtime"
    },
    "series": {
      "url": "/api/series.json",
      "description": "Multi-part renter article series",
      "format": "json",
      "updated": "realtime"
    },
    "topics": {
      "url": "/api/topics.json",
      "description": "Article taxonomy organized by topic tags",
      "format": "json",
      "updated": "realtime"
    },
    "index": {
      "url": "/index.json",
      "description": "Site structure and navigation index",
      "format": "json",
      "updated": "realtime"
    },
    "feed": {
      "url": "/feed.xml",
      "description": "RSS/Atom feed of latest renter articles",
      "format": "xml",
      "updated": "realtime"
    },
    "sitemap": {
      "url": "/sitemap.xml",
      "description": "XML sitemap for all pages",
      "format": "xml",
      "updated": "realtime"
    }
  },
  "capabilities": {
    "search": true,
    "filtering": [
      "article_stage",
      "topic",
      "series",
      "tags"
    ],
    "structured_data": true,
    "json_ld": true
  },
  "content_features": {
    "series_support": true,
    "estimated_reading_time": true,
    "checklists": true,
    "positive_and_negative_tradeoffs": true,
    "renter_red_flags": true
  },
