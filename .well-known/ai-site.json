    "modifications_allowed": true
  },
  "attribution": {
    "required": true,
    "format": "[Article Title], Decent Apartments (https://decent.apartments)",
    "link_back_appreciated": true
  },
  "contact": {
    "website": "https://decent.apartments"
  },
  "technical": {
